# Path (relative to your home directory, $HOME) to THIS theme's OWN folder
# inside your Obsidian vault — not the parent "themes" directory. Must end
# with a trailing slash. Used by `npm run deploy` and `npm run watch` to sync
# theme.css + manifest.json into your Obsidian install.
#
# Replace with your own vault path, then rename this file to ".env".
OBSIDIAN_PATH='/Documents/Vault-Name/.obsidian/themes/Primary Simplified/'
